{
  "name": "coding-practice",
  "version": "0.0.1",
  "description": "JS/TS/Java/Kotlin/Python coding-practice projects",
  "license": "MIT",
  "keywords": [
    "eslint",
    "prettier"
  ],
  "scripts": {
    "build": "npm-run-all clean check --",
    "check": "tsc",
    "clean": "rimraf coverage lib",
    "format": "run-s format:*",
    "format:eslint": "npm run lint -- --fix",
    "format:prettier": "prettier --write 'src/{**/*,*}.{json,js,jsx,ts,tsx,md,yml,yaml,html,scss}'",
    "lint": "eslint 'src/{**/*,*}.{json,js,jsx,ts,tsx}'",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "start": "nodemon --exec ts-node src/index.ts",
    "test": "jest --colors",
    "test:coverage": "npm run test -- --coverage",
    "watch": "npm run build -- --watch"
  },
  "engines": {
    "node": ">= 10"
  },
  "main": "src/index.ts",
  "devDependencies": {
    "@babel/cli": "^7.11.6",
    "@babel/core": "^7.11.6",
    "@babel/plugin-transform-runtime": "^7.11.5",
    "@babel/preset-env": "^7.11.5",
    "@babel/preset-typescript": "^7.10.4",
    "@babel/runtime": "^7.11.2",
    "@semantic-release/changelog": "~5.0.1",
    "@semantic-release/git": "~9.0.0",
    "@types/fs-extra": "^9.0.1",
    "@types/glob": "^7.1.3",
    "@types/jest": "^26.0.14",
    "@types/mkdirp": "^1.0.1",
    "@types/mocha": "^8.0.3",
    "@types/node": "^14.11.2",
    "@types/resolve": "^1.17.1",
    "@types/supertest": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^4.4.0",
    "@typescript-eslint/eslint-plugin-tslint": "^4.4.0",
    "@typescript-eslint/parser": "^4.4.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^26.5.0",
    "core-js": "^3.6.5",
    "eslint": "^7.10.0",
    "eslint-config-airbnb": "^18.2.0",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-config-airbnb-typescript": "^11.0.0",
    "eslint-config-prettier": "^6.12.0",
    "eslint-config-standard": "^14.1.1",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jest": "^24.0.2",
    "eslint-plugin-json": "^2.1.2",
    "eslint-plugin-jsx-a11y": "^6.3.1",
    "eslint-plugin-mocha": "^8.0.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.1.4",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-react": "^7.21.3",
    "eslint-plugin-react-hooks": "^4.1.2",
    "eslint-plugin-security": "^1.4.0",
    "eslint-plugin-standard": "^4.0.1",
    "eslint-plugin-tsc": "^2.0.0",
    "husky": ">=4",
    "jest": "^26.5.0",
    "lint-staged": ">=10",
    "nodemon": "^2.0.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.1.2",
    "rimraf": "^3.0.2",
    "semantic-release": "^17.1.2",
    "stylelint": "^13.7.2",
    "stylelint-config-standard": "^20.0.0",
    "tree-node-cli": "^1.4.0",
    "typescript": "^4.0.3"
  },
  "dependencies": {}
}
