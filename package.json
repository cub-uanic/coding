{
  "scripts": {
    "test": "jest"
  },
  "jest": {
    "coverageDirectory": "coverage",
    "coverageProvider": "v8",
    "testEnvironment": "node",
    "verbose": true,
    "collectCoverageFrom": [
      "**/*.{js,jsx,ts}",
      "!**/node_modules/**",
      "!**/vendor/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": -10
      }
    }
  },
  "devDependencies": {
    "jest": "^26.4.2"
  },
  "dependencies": {
    "@jest/globals": "^26.4.2"
  }
}
